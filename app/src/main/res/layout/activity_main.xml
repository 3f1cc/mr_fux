<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Status bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/status_left"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="CF"
            android:textColor="@color/status_text"
            android:textSize="14sp"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/status_right"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/status_text"
            android:textSize="12sp"
            android:fontFamily="monospace" />

    </LinearLayout>

    <!-- Grand staff view -->
    <com.mrfux.ui.StaffView
        android:id="@+id/staff_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Navigation row: cursor + pitch -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingBottom="2dp">

        <Button
            android:id="@+id/btn_cursor_left"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="◀"
            style="@style/ControlButton" />

        <Button
            android:id="@+id/btn_pitch_down"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="▼"
            style="@style/ControlButton" />

        <Button
            android:id="@+id/btn_voice_toggle"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.5"
            android:text="CF"
            style="@style/ControlButton" />

        <Button
            android:id="@+id/btn_pitch_up"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="▲"
            style="@style/ControlButton" />

        <Button
            android:id="@+id/btn_cursor_right"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="▶"
            style="@style/ControlButton" />

    </LinearLayout>

    <!-- Action row: play, check, settings, save, load -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingBottom="4dp">

        <Button
            android:id="@+id/btn_play"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="▶"
            style="@style/ControlButton" />

        <Button
            android:id="@+id/btn_check"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.5"
            android:text="Check"
            style="@style/ControlButton" />

        <Button
            android:id="@+id/btn_settings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="⚙"
            style="@style/ControlButton" />

        <Button
            android:id="@+id/btn_save"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Save"
            style="@style/ControlButton" />

        <Button
            android:id="@+id/btn_load"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Load"
            style="@style/ControlButton" />

    </LinearLayout>

</LinearLayout>
